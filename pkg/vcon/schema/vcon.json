{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ietf.org/vcon/schemas/unsigned-vcon.json",
  "title": "vCon JSON Container (draft-ietf-vcon-vcon-core-02)",
  "type": "object",
  "required": [
    "uuid",
    "created_at",
    "parties"
  ],
  "properties": {
    "vcon": {
      "type": "string",
      "const": "0.4.0",
      "description": "Deprecated version identifier for this vCon draft"
    },
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "string"
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Extension name tokens used in this vCon"
    },
    "critical": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Incompatible extension tokens that MUST be understood"
    },
    "redacted": {
      "type": "object",
      "properties": {
        "uuid": {
          "type": "string",
          "format": "uuid"
        },
        "type": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "content_hash": {
          "$ref": "#/$defs/content_hash_value"
        }
      },
      "required": ["uuid", "type"]
    },
    "amended": {
      "type": "object",
      "properties": {
        "uuid": {
          "type": "string",
          "format": "uuid"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "content_hash": {
          "$ref": "#/$defs/content_hash_value"
        }
      }
    },
    "group": {
      "type": "array",
      "items": {}
    },
    "parties": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/party"
      }
    },
    "dialog": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dialog"
      }
    },
    "analysis": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/analysis"
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/attachment"
      }
    }
  },
  "$defs": {
    "content_hash_value": {
      "description": "Content hash in format 'algorithm-base64url_hash' — single string or array",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "int_or_array": {
      "description": "Single integer or array of integers",
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      ]
    },
    "party": {
      "type": "object",
      "properties": {
        "tel": {
          "type": "string"
        },
        "stir": {
          "type": "string"
        },
        "mailto": {
          "type": "string"
        },
        "sip": {
          "type": "string"
        },
        "did": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "validation": {
          "type": "string"
        },
        "gmlpos": {
          "type": "string"
        },
        "civicaddress": {
          "$ref": "#/$defs/civicaddress"
        },
        "uuid": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "civicaddress": {
      "type": "object",
      "properties": {
        "country": { "type": "string" },
        "a1": { "type": "string" },
        "a2": { "type": "string" },
        "a3": { "type": "string" },
        "a4": { "type": "string" },
        "a5": { "type": "string" },
        "a6": { "type": "string" },
        "prd": { "type": "string" },
        "pod": { "type": "string" },
        "sts": { "type": "string" },
        "hno": { "type": "string" },
        "hns": { "type": "string" },
        "lmk": { "type": "string" },
        "loc": { "type": "string" },
        "flr": { "type": "string" },
        "nam": { "type": "string" },
        "pc": { "type": "string" }
      }
    },
    "dialog": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "duration": {
          "type": "number",
          "minimum": 0
        },
        "parties": {
          "anyOf": [
            { "type": "integer", "minimum": 0 },
            {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0
              }
            },
            {
              "type": "array",
              "items": {
                "oneOf": [
                  { "type": "integer", "minimum": 0 },
                  {
                    "type": "array",
                    "items": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                ]
              }
            }
          ]
        },
        "originator": {
          "type": "integer",
          "minimum": 0
        },
        "mediatype": {
          "type": "string"
        },
        "filename": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "encoding": {
          "type": "string",
          "enum": ["base64url", "json", "none"]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "content_hash": {
          "$ref": "#/$defs/content_hash_value"
        },
        "disposition": {
          "type": "string",
          "enum": [
            "no-answer",
            "congestion",
            "failed",
            "busy",
            "hung-up",
            "voicemail-no-message"
          ]
        },
        "party_history": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/party_history"
          }
        },
        "session_id": {
          "oneOf": [
            { "$ref": "#/$defs/session_id" },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/session_id" }
            }
          ]
        },
        "transferee": {
          "type": "integer",
          "minimum": 0
        },
        "transferor": {
          "type": "integer",
          "minimum": 0
        },
        "transfer_target": {
          "$ref": "#/$defs/int_or_array"
        },
        "original": {
          "$ref": "#/$defs/int_or_array"
        },
        "consultation": {
          "$ref": "#/$defs/int_or_array"
        },
        "target_dialog": {
          "$ref": "#/$defs/int_or_array"
        },
        "application": {
          "type": "string"
        },
        "message_id": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "start"
      ]
    },
    "party_history": {
      "type": "object",
      "properties": {
        "party": {
          "type": "integer",
          "minimum": 0
        },
        "event": {
          "type": "string",
          "enum": ["join", "drop", "hold", "unhold", "mute", "unmute", "keydown", "keyup"]
        },
        "time": {
          "type": "string",
          "format": "date-time"
        },
        "button": {
          "type": "string",
          "description": "Required for keydown/keyup events"
        }
      },
      "required": [
        "party",
        "event",
        "time"
      ]
    },
    "session_id": {
      "type": "object",
      "properties": {
        "local": { "type": "string" },
        "remote": { "type": "string" }
      },
      "required": ["local", "remote"]
    },
    "analysis": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "dialog": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "array", "items": {"type": "integer", "minimum": 0} }
          ]
        },
        "mediatype": {
          "type": "string"
        },
        "filename": {
          "type": "string"
        },
        "vendor": {
          "type": "string"
        },
        "product": {
          "type": "string"
        },
        "schema": {
          "type": ["string", "object"]
        },
        "body": {
          "type": ["string", "object", "array"]
        },
        "encoding": {
          "type": "string",
          "enum": ["base64url", "json", "none"]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "content_hash": {
          "$ref": "#/$defs/content_hash_value"
        }
      },
      "required": [
        "type"
      ]
    },
    "attachment": {
      "type": "object",
      "properties": {
        "body": {
          "type": "string"
        },
        "encoding": {
          "type": "string",
          "enum": ["base64url", "json", "none"]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "content_hash": {
          "$ref": "#/$defs/content_hash_value"
        },
        "dialog": {
          "type": "integer",
          "minimum": 0
        },
        "party": {
          "type": "integer",
          "minimum": 0
        },
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "mediatype": {
          "type": "string"
        },
        "filename": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        }
      },
      "required": [
        "start",
        "party"
      ]
    }
  }
}
